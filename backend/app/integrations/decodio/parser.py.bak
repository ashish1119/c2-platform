import json
import socket
import time
from typing import Any, Dict, Optional


def parse_decodio_message(msg: str) -> Dict[str, Any]:
    """
    Parse a single Decodio JSON message string.

    Args:
        msg: The JSON message string

    Returns:
        Parsed dictionary with extracted parameters
    """
    try:
        data = json.loads(msg)
    except json.JSONDecodeError as e:
        return {"error": f"JSON decode error: {e}", "raw_message": msg}

    # Extract the specified parameters
    parsed = {
        "DeviceId": data.get("DeviceId"),
        "DeviceAlias": data.get("DeviceAlias"),
        "StreamId": data.get("StreamId"),
        "Protocol": data.get("Protocol"),
        "Power": data.get("Power"),
        "ChannelStatus": data.get("ChannelStatus"),
        "Running": data.get("Running"),
        "Disabled": data.get("Disabled"),
        "Lock": data.get("Lock"),
        "ModeId": data.get("ModeId"),
        "SR": data.get("SR"),  # Sample Rate
        "Reason": data.get("Reason"),
        "Label": data.get("Label"),
        "Position": data.get("Position"),
        "TimeStamp": data.get("TimeStamp"),
        "Uuid": data.get("Uuid"),
        "Version": data.get("Version"),
        "Command": data.get("Command"),
        "Color": data.get("Color"),
        "Notes": data.get("Notes"),
        "raw_message": msg,
        "parsed_at": time.time()
    }

    return parsed


class DecodioDataParser:
    def __init__(self, host: Optional[str] = None, port: Optional[int] = None, file_path: Optional[str] = None):
        self.host = host
        self.port = port
        self.file_path = file_path
        self.buffer = ""
        self.sock: Optional[socket.socket] = None
        self.output_file = "decodio_recv_data.txt"

    def connect_tcp(self) -> bool:
        """Connect to Decodio TCP server."""
        if not self.host or not self.port:
            return False

        try:
            self.sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.sock.settimeout(5.0)
            self.sock.connect((self.host, self.port))
            return True
        except (socket.error, OSError) as e:
            print(f"TCP connection failed: {e}")
            return False

    def read_from_tcp(self) -> Optional[Dict[str, Any]]:
        """Read and parse messages from TCP stream."""
        if not self.sock:
            return None

        try:
            data = self.sock.recv(4096)
            if not data:
                return None

            self.buffer += data.decode('utf-8', errors='ignore')

            # Split on }{ to handle concatenated JSON
            messages = []
            while "}{" in self.buffer:
                parts = self.buffer.split("}{", 1)
                if len(parts) == 2:
                    msg = parts[0] + "}"
                    messages.append(msg)
                    self.buffer = "{" + parts[1]

            # Check for complete message at end
            if self.buffer.endswith("}"):
                messages.append(self.buffer)
                self.buffer = ""

            parsed_messages = []
            for msg in messages:
                parsed = parse_decodio_message(msg)
                if parsed:
                    parsed_messages.append(parsed)
                    self.save_to_file(parsed)

            return parsed_messages if parsed_messages else None

        except (socket.error, OSError) as e:
            print(f"TCP read error: {e}")
            return None

    def read_from_file(self) -> Optional[Dict[str, Any]]:
        """Read and parse messages from file."""
        if not self.file_path:
            return None

        try:
            with open(self.file_path, 'r') as f:
                lines = f.readlines()

            parsed_messages = []
            for line in lines:
                line = line.strip()
                if line:
                    parsed = parse_decodio_message(line)
                    if parsed:
                        parsed_messages.append(parsed)
                        self.save_to_file(parsed)

            return parsed_messages if parsed_messages else None

        except FileNotFoundError:
            print(f"File not found: {self.file_path}")
            return None
        except Exception as e:
            print(f"File read error: {e}")
            return None

    def save_to_file(self, parsed_data: Dict[str, Any]) -> None:
        """Save parsed data to output file."""
        try:
            with open(self.output_file, 'a') as f:
                f.write(json.dumps(parsed_data, indent=2) + "\n")
        except Exception as e:
            print(f"Error saving to file: {e}")

    def parse_data(self, timeout: float = 5.0) -> Optional[Dict[str, Any]]:
        """
        Main parsing method that tries TCP first, then file mode.

        Args:
            timeout: Maximum time to wait for data in LIVE MODE

        Returns:
            Parsed data dictionary or None
        """
        # Try LIVE MODE first
        if self.connect_tcp():
            print("Connected to Decodio TCP server - LIVE MODE")
            start_time = time.time()
            while time.time() - start_time < timeout:
                data = self.read_from_tcp()
                if data:
                    return data
                time.sleep(0.1)  # Small delay to avoid busy loop
            print("No data received within timeout - switching to FILE MODE")
            return self.read_from_file()
        else:
            print("TCP connection failed or not configured - switching to FILE MODE")
            return self.read_from_file()

    def close(self) -> None:
        """Close TCP connection."""
        if self.sock:
            self.sock.close()
            self.sock = None


# Convenience function for FastAPI integration
def parse_decodio_data(host: Optional[str] = None, port: Optional[int] = None, file_path: Optional[str] = None, timeout: float = 5.0) -> Optional[Dict[str, Any]]:
    """
    Parse Decodio data using the parser.

    Args:
        host: TCP server host
        port: TCP server port
        file_path: Path to JSON file (fallback)
        timeout: Timeout for LIVE MODE

    Returns:
        Parsed data or None
    """
    parser = DecodioDataParser(host=host, port=port, file_path=file_path)
    try:
        return parser.parse_data(timeout=timeout)
    finally:
