POSTGRES_USER=c2user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=c2db

DATABASE_URL=postgresql+asyncpg://c2user:change-me@postgres:5432/c2db

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ENVIRONMENT=development
ACCESS_TOKEN_EXPIRE_MINUTES=60
ACCESS_TOKEN_COOKIE_SECURE=false
REDIS_URL=redis://redis:6379/0
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
TCP_LISTENER_ENABLED=true
TCP_LISTENER_HOST=0.0.0.0
TCP_LISTENER_PORT=9300
TCP_LISTENER_IDLE_TIMEOUT_SECONDS=30
TCP_LISTENER_MAX_LINE_BYTES=16384